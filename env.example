import { AlertTriangle, X } from "lucide-react";
import { EducationItem } from "../types";

interface DeleteConfirmModalProps {
  isOpen: boolean;
  item: EducationItem | null;
  onConfirm: () => void;
  onCancel: () => void;
}

export default function DeleteConfirmModal({ isOpen, item, onConfirm, onCancel }: DeleteConfirmModalProps) {
  if (!isOpen || !item) return null;

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center p-4 overflow-hidden" id="delete-confirm-modal">
      {/* Backdrop overlay */}
      <div
        onClick={onCancel}
        className="fixed inset-0 bg-slate-900/60 backdrop-blur-xs transition-opacity duration-300"
      />

      {/* Modal content */}
      <div
        className="relative bg-white rounded-3xl border border-slate-100 max-w-md w-full shadow-2xl p-6 overflow-hidden z-10 animate-[fadeIn_0.2s_ease-out]"
      >
        {/* Close button */}
        <button
          onClick={onCancel}
          className="absolute top-4 right-4 p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-50 rounded-xl transition-all"
          id="close-delete-modal-btn"
        >
          <X className="w-5 h-5" />
        </button>

        <div className="flex flex-col items-center text-center mt-2">
          {/* Warning Icon Container */}
          <div className="w-14 h-14 bg-rose-50 rounded-full flex items-center justify-center text-rose-500 mb-4 animate-[bounce_1s_infinite]">
            <AlertTriangle className="w-7 h-7" />
          </div>

          <h3 className="text-lg font-bold text-slate-800 tracking-tight mb-2">
            项目の削除確認
          </h3>
          
          <p className="text-sm text-slate-500 leading-relaxed max-w-sm mb-6">
            本当に「<span className="font-semibold text-slate-800">{item.title}</span>」を削除しますか？
            <br />
            この操作を実行すると、進捗データは永久に削除され元に戻せません。
          </p>

          <div className="flex items-center gap-3 w-full">
            <button
              onClick={onCancel}
              className="flex-1 px-4 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold rounded-2xl transition-colors text-sm"
              id="cancel-delete-btn"
            >
              キャンセル
            </button>
            <button
              onClick={onConfirm}
              className="flex-1 px-4 py-3 bg-rose-600 hover:bg-rose-700 text-white font-bold rounded-2xl shadow-md shadow-rose-600/10 hover:shadow-rose-700/20 transition-all text-sm"
              id="confirm-delete-btn"
            >
              削除する
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}
