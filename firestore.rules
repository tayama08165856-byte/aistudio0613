import React, { useState, useEffect } from "react";
import { 
  Cloud, 
  CloudRain, 
  Database, 
  Download, 
  Upload, 
  Trash2, 
  Loader2, 
  CheckCircle, 
  AlertTriangle, 
  LogOut, 
  FileJson, 
  RefreshCw,
  Clock,
  HardDrive
} from "lucide-react";
import { auth, googleSignIn, googleSignOut, getAccessToken } from "../firebase";
import { EducationItem } from "../types";

interface GoogleDriveSyncProps {
  groupCode: string;
  items: EducationItem[];
  categories: string[];
  onRestoreData: (backupCategories: string[], backupItems: any[], overwrite: boolean) => Promise<boolean>;
  userId: string | null;
  setUserId: (uid: string) => void;
  setAlertMessage: (msg: { type: "success" | "error"; text: string } | null) => void;
}

interface BackupFile {
  id: string;
  name: string;
  createdTime: string;
  size?: string;
}

export default function GoogleDriveSync({
  groupCode,
  items,
  categories,
  onRestoreData,
  userId,
  setUserId,
  setAlertMessage
}: GoogleDriveSyncProps) {
  const [googleUser, setGoogleUser] = useState<any>(null);
  const [accessToken, setAccessToken] = useState<string | null>(null);
  const [isLoadingBackups, setIsLoadingBackups] = useState(false);
  const [isBackupActionLoading, setIsBackupActionLoading] = useState(false);
  const [backups, setBackups] = useState<BackupFile[]>([]);
  const [isConfirmingRestore, setIsConfirmingRestore] = useState<string | null>(null); // File ID of backup being restored
  const [restoreMode, setRestoreMode] = useState<"merge" | "overwrite">("merge");
  
  // Track active operations for UI spinners
  const [activeActionId, setActiveActionId] = useState<string | null>(null);
  const [backupSuffix, setBackupSuffix] = useState("");

  // Monitor Auth State
  useEffect(() => {
    const unsubscribe = auth.onAuthStateChanged((user) => {
      if (user && !user.isAnonymous) {
        setGoogleUser(user);
        // Try getting token
        getAccessToken().then((token) => {
          if (token) setAccessToken(token);
        });
      } else {
        setGoogleUser(null);
        setAccessToken(null);
      }
    });
    return () => unsubscribe();
  }, []);

  // Fetch list of backup files from Google Drive
  const fetchBackupsList = async (tokenToUse: string | null = accessToken) => {
    const activeToken = tokenToUse || accessToken;
    if (!activeToken) return;

    setIsLoadingBackups(true);
    try {
      // Query files that contain 'medical_education_backup' in name, are json, and not trashed
      const q = "name contains 'medical_education_backup' and mimeType = 'application/json' and trashed = false";
      const url = `https://www.googleapis.com/drive/v3/files?q=${encodeURIComponent(q)}&fields=files(id,name,createdTime,size)&orderBy=createdTime desc`;

      const response = await fetch(url, {
        headers: {
          Authorization: `Bearer ${activeToken}`,
        },
      });

      if (!response.ok) {
        if (response.status === 401) {
          // Token expired
          setAccessToken(null);
          throw new Error("Google Driveへの接続期限が切れました。再接続してください。");
        }
        throw new Error("バックアップ一覧の取得に失敗しました。");
      }

      const data = await response.json();
      setBackups(data.files || []);
    } catch (error: any) {
      console.error("Fetch backups error:", error);
      setAlertMessage({ type: "error", text: error.message || "Google Driveからのデータ取得に失敗しました。" });
    } finally {
      setIsLoadingBackups(false);
    }
  };

  // Fetch backups on connection
  useEffect(() => {
    if (accessToken) {
      fetchBackupsList();
    } else {
      setBackups([]);
    }
  }, [accessToken]);

  // Handle Sign In / Connecting
  const handleConnectDrive = async () => {
    setIsBackupActionLoading(true);
    try {
      const result = await googleSignIn();
      if (result) {
        setGoogleUser(result.user);
        setAccessToken(result.accessToken);
        setUserId(result.user.uid);
        setAlertMessage({ type: "success", text: "Google Driveとの連携が完了しました！" });
        // Fetch list with the newly acquired token
        await fetchBackupsList(result.accessToken);
      }
    } catch (error: any) {
      console.error("Connection failed:", error);
      setAlertMessage({ type: "error", text: "Google Driveへの接続に失敗しました。" });
    } finally {
      setIsBackupActionLoading(false);
    }
  };

  // Handle Disconnecting
  const handleDisconnectDrive = async () => {
    if (window.confirm("Google Driveとの接続を解除しますか？（バックアップデータは削除されません）")) {
      try {
        await googleSignOut();
        setGoogleUser(null);
        setAccessToken(null);
        setBackups([]);
        setAlertMessage({ type: "success", text: "Google Driveとの接続を解除しました。" });
      } catch (error) {
        console.error("Signout error:", error);
      }
    }
  };

  // Save/Create a backup to Google Drive
  const handleCreateBackup = async () => {
    if (!accessToken) {
      setAlertMessage({ type: "error", text: "Google Driveに接続されていません。" });
      return;
    }

    setIsBackupActionLoading(true);
    try {
      const timestamp = new Date().toISOString();
      const backupData = {
        app: "CE_Medical_Education_App_Backup",
        version: "1.0",
        timestamp,
        groupCode,
        categories,
        items
      };

      const dateStr = new Date().toLocaleString("ja-JP", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      }).replace(/[\/\s:]/g, "-");

      const cleanSuffix = backupSuffix.trim().replace(/[\/\s:\\*?"<>|]/g, "_");
      const filename = cleanSuffix 
        ? `medical_education_backup_${groupCode}_${cleanSuffix}_${dateStr}.json`
        : `medical_education_backup_${groupCode}_${dateStr}.json`;

      const metadata = {
        name: filename,
        mimeType: "application/json",
        description: `医療系教育アプリの進捗バックアップデータ（同期コード: ${groupCode}、メモ: ${backupSuffix || 'なし'}）`
      };

      const fileContent = JSON.stringify(backupData, null, 2);
      const blob = new Blob([fileContent], { type: "application/json" });

      const form = new FormData();
      form.append("metadata", new Blob([JSON.stringify(metadata)], { type: "application/json" }));
      form.append("file", blob);

      const response = await fetch("https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart", {
        method: "POST",
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
        body: form,
      });

      if (!response.ok) {
        throw new Error("Google Driveへのバックアップ保存に失敗しました。");
      }

      setAlertMessage({ type: "success", text: `バックアップ「${filename}」をGoogle Driveに保存しました。` });
      setBackupSuffix("");
      // Refresh list
      await fetchBackupsList();
    } catch (error: any) {
      console.error("Backup error:", error);
      setAlertMessage({ type: "error", text: error.message || "バックアップの作成に失敗しました。" });
    } finally {
      setIsBackupActionLoading(false);
    }
  };

  // Restore/Download data from a backup file
  const handleRestoreBackup = async (fileId: string) => {
    if (!accessToken) return;
    
    // Explicit user confirmation for data mutation (MANDATORY per workspace integration skill)
    const backupName = backups.find(b => b.id === fileId)?.name || "バックアップデータ";
    const modeText = restoreMode === "overwrite" ? "【上書き復元：現在のデータはすべて削除されます】" : "【マージ復元：既存データに追加されます】";
    
    const confirmed = window.confirm(
      `本当に「${backupName}」からデータを復元しますか？\n${modeText}\nこの操作は元に戻せません。`
    );
    if (!confirmed) return;

    setActiveActionId(fileId);
    try {
      const url = `https://www.googleapis.com/drive/v3/files/${fileId}?alt=media`;
      const response = await fetch(url, {
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
      });

      if (!response.ok) {
        throw new Error("バックアップデータのダウンロードに失敗しました。");
      }

      const backupContent = await response.json();
      
      // Basic format validation
      if (!backupContent || backupContent.app !== "CE_Medical_Education_App_Backup") {
        throw new Error("選択されたファイルは有効な教育アプリのバックアップデータではありません。");
      }

      const backupCategories = backupContent.categories || [];
      const backupItems = backupContent.items || [];

      const success = await onRestoreData(backupCategories, backupItems, restoreMode === "overwrite");
      if (success) {
        setAlertMessage({ 
          type: "success", 
          text: `Google Driveからデータ（カテゴリー ${backupCategories.length}件、研修項目 ${backupItems.length}件）を正常に復元しました！` 
        });
        setIsConfirmingRestore(null);
      }
    } catch (error: any) {
      console.error("Restore error:", error);
      setAlertMessage({ type: "error", text: error.message || "データの復元に失敗しました。" });
    } finally {
      setActiveActionId(null);
    }
  };

  // Delete a backup file from Google Drive
  const handleDeleteBackup = async (fileId: string) => {
    if (!accessToken) return;

    // Explicit user confirmation for destructive operations (MANDATORY)
    const backupName = backups.find(b => b.id === fileId)?.name || "このファイル";
    const confirmed = window.confirm(
      `本当にGoogle Drive上のバックアップファイル「${backupName}」を削除しますか？\nこの操作はGoogle Driveから直接ファイルを削除します。`
    );
    if (!confirmed) return;

    setActiveActionId(fileId);
    try {
      const response = await fetch(`https://www.googleapis.com/drive/v3/files/${fileId}`, {
        method: "DELETE",
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
      });

      if (!response.ok) {
        throw new Error("Google Driveからのファイル削除に失敗しました。");
      }

      setAlertMessage({ type: "success", text: "バックアップファイルをGoogle Driveから削除しました。" });
      // Update local state list
      setBackups(prev => prev.filter(b => b.id !== fileId));
    } catch (error: any) {
      console.error("Delete backup error:", error);
      setAlertMessage({ type: "error", text: error.message || "ファイルの削除に失敗しました。" });
    } finally {
      setActiveActionId(null);
    }
  };

  // Render nicely
  return (
    <div className="bg-slate-50 border border-slate-200 rounded-2xl p-4 space-y-4" id="google-drive-sync-widget">
      {/* Header section with connection state */}
      <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-slate-200 pb-3">
        <div className="flex items-center gap-2">
          <div className="p-1.5 bg-blue-100 text-blue-700 rounded-xl">
            <Cloud className="w-4 h-4" />
          </div>
          <div>
            <h3 className="text-xs font-black text-slate-800 flex items-center gap-1.5">
              <span>Google Drive 自動保存・バックアップ連携</span>
              {googleUser && accessToken ? (
                <span className="inline-flex items-center gap-1 text-[9px] bg-emerald-50 text-emerald-700 font-extrabold px-1.5 py-0.5 rounded-full border border-emerald-100">
                  連携完了
                </span>
              ) : (
                <span className="inline-flex items-center gap-1 text-[9px] bg-amber-50 text-amber-700 font-extrabold px-1.5 py-0.5 rounded-full border border-amber-100">
                  未連携
                </span>
              )}
            </h3>
            {googleUser ? (
              <p className="text-[10px] text-slate-500 font-semibold mt-0.5">
                アカウント: <span className="text-slate-700 font-bold">{googleUser.email}</span>
                {!accessToken && " (※再接続が必要です)"}
              </p>
            ) : (
              <p className="text-[10px] text-slate-400 font-semibold mt-0.5">
                Google Driveと連携すると、別のパソコン間でのデータの同期・バックアップ・復元が可能になります。
              </p>
            )}
          </div>
        </div>

        {/* Action buttons for authentication */}
        <div className="flex items-center gap-2">
          {googleUser ? (
            <>
              {!accessToken && (
                <button
                  onClick={handleConnectDrive}
                  disabled={isBackupActionLoading}
                  className="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-[10px] font-black rounded-lg transition-all flex items-center gap-1 shadow-xs cursor-pointer"
                >
                  <RefreshCw className="w-3 h-3" />
                  <span>Google Driveを再認証</span>
                </button>
              )}
              <button
                onClick={handleDisconnectDrive}
                className="px-3 py-1.5 bg-slate-100 hover:bg-rose-50 hover:text-rose-600 text-slate-600 text-[10px] font-black rounded-lg transition-all border border-slate-200 flex items-center gap-1 cursor-pointer"
                title="接続を解除"
              >
                <LogOut className="w-3 h-3" />
                <span>連携解除</span>
              </button>
            </>
          ) : (
            <button
              onClick={handleConnectDrive}
              disabled={isBackupActionLoading}
              className="gsi-material-button text-xs py-1.5 px-3.5 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 rounded-xl shadow-xs transition-all flex items-center gap-2 cursor-pointer font-black"
            >
              <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" className="w-4 h-4">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
              </svg>
              <span>Googleでログインして連携</span>
            </button>
          )}
        </div>
      </div>

      {googleUser && accessToken ? (
        <div className="space-y-4">
          {/* Create Backup Button */}
          <div className="flex flex-col gap-3 p-3 bg-blue-50/20 border border-blue-100/40 rounded-xl">
            <div className="space-y-0.5">
              <p className="text-[11px] font-extrabold text-slate-800">
                現在のデータ状態をGoogle Driveに保存する
              </p>
              <p className="text-[10px] text-slate-400 font-semibold">
                進捗状況（{items.length}件）とカテゴリー情報（{categories.length}件）をGoogle Driveへバックアップします。
              </p>
            </div>
            
            <div className="flex flex-col sm:flex-row items-stretch sm:items-center gap-2">
              <input
                type="text"
                value={backupSuffix}
                onChange={(e) => setBackupSuffix(e.target.value)}
                placeholder="コピー用メモ・識別タグ（例: 第1期生用、外科研修バックアップ等）"
                className="flex-1 px-3 py-1.5 rounded-lg border border-slate-200 bg-white font-semibold text-slate-700 text-[10px] outline-none focus:border-blue-500"
                maxLength={30}
              />
              <button
                onClick={handleCreateBackup}
                disabled={isBackupActionLoading}
                className="py-1.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-extrabold text-[11px] rounded-lg transition-all shadow-md shadow-blue-600/10 flex items-center justify-center gap-1.5 cursor-pointer shrink-0"
              >
                {isBackupActionLoading ? (
                  <Loader2 className="w-3.5 h-3.5 animate-spin" />
                ) : (
                  <Upload className="w-3.5 h-3.5" />
                )}
                <span>現在データをバックアップ</span>
              </button>
            </div>
          </div>

          {/* Backup List section */}
          <div className="space-y-2">
            <div className="flex items-center justify-between">
              <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-wider flex items-center gap-1">
                <HardDrive className="w-3.5 h-3.5" />
                <span>Google Drive上のバックアップ履歴 ({backups.length}件)</span>
              </h4>
              <button
                onClick={() => fetchBackupsList()}
                disabled={isLoadingBackups}
                className="text-slate-400 hover:text-blue-600 text-[10px] font-bold flex items-center gap-0.5"
                title="一覧を更新"
              >
                <RefreshCw className={`w-3 h-3 ${isLoadingBackups ? 'animate-spin' : ''}`} />
                <span>更新</span>
              </button>
            </div>

            {isLoadingBackups ? (
              <div className="py-8 flex flex-col items-center justify-center text-slate-400 gap-2">
                <Loader2 className="w-6 h-6 animate-spin text-blue-500" />
                <span className="text-[10px] font-bold">Google Driveからデータを読み込んでいます...</span>
              </div>
            ) : backups.length === 0 ? (
              <div className="py-8 text-center border-2 border-dashed border-slate-200 rounded-xl bg-white">
                <FileJson className="w-8 h-8 text-slate-300 mx-auto mb-1.5" />
                <p className="text-[11px] text-slate-500 font-extrabold">バックアップファイルがありません。</p>
                <p className="text-[10px] text-slate-400 mt-0.5">上のボタンから最初のバックアップを作成してください。</p>
              </div>
            ) : (
              <div className="max-h-56 overflow-y-auto border border-slate-200 rounded-xl bg-white divide-y divide-slate-100 shadow-inner">
                {backups.map((file) => {
                  const isRestoringThis = isConfirmingRestore === file.id;
                  const isActionLoading = activeActionId === file.id;
                  
                  return (
                    <div key={file.id} className="p-3 hover:bg-slate-50/50 flex flex-col space-y-2.5">
                      <div className="flex items-center justify-between gap-2">
                        <div className="min-w-0">
                          <p className="text-[11px] font-bold text-slate-700 truncate" title={file.name}>
                            {file.name}
                          </p>
                          <p className="text-[9px] text-slate-400 font-semibold flex items-center gap-1 mt-0.5">
                            <Clock className="w-3 h-3 text-slate-300" />
                            <span>{new Date(file.createdTime).toLocaleString("ja-JP")}</span>
                            {file.size && (
                              <span className="bg-slate-100 text-slate-500 px-1 py-0.2 rounded font-mono text-[8px]">
                                {(parseInt(file.size) / 1024).toFixed(1)} KB
                              </span>
                            )}
                          </p>
                        </div>

                        {/* File Action Controls */}
                        {!isRestoringThis && (
                          <div className="flex items-center gap-1.5 shrink-0">
                            <button
                              onClick={() => {
                                setIsConfirmingRestore(file.id);
                                setRestoreMode("merge");
                              }}
                              disabled={isActionLoading}
                              className="px-2.5 py-1.5 bg-slate-100 hover:bg-blue-50 hover:text-blue-600 text-slate-600 text-[10px] font-black rounded-lg transition-colors flex items-center gap-0.5 cursor-pointer"
                              title="データを復元"
                            >
                              <Download className="w-3 h-3" />
                              <span>復元</span>
                            </button>
                            <button
                              onClick={() => handleDeleteBackup(file.id)}
                              disabled={isActionLoading}
                              className="px-2 py-1.5 hover:bg-rose-50 hover:text-rose-600 text-slate-400 transition-colors rounded-lg cursor-pointer"
                              title="バックアップを削除"
                            >
                              {isActionLoading ? (
                                <Loader2 className="w-3 h-3 animate-spin" />
                              ) : (
                                <Trash2 className="w-3 h-3" />
                              )}
                            </button>
                          </div>
                        )}
                      </div>

                      {/* Expanded Restore confirmation panel within the item row */}
                      {isRestoringThis && (
                        <div className="p-2.5 bg-blue-50/60 border border-blue-100 rounded-lg flex flex-col space-y-2 animate-[fadeIn_0.1s_ease-out]">
                          <div className="flex items-center gap-1 text-[10px] font-black text-blue-900">
                            <AlertTriangle className="w-3.5 h-3.5 text-blue-600" />
                            <span>復元方法を選択してください:</span>
                          </div>
                          
                          {/* Radio/Segmented Control for Mode Selection */}
                          <div className="grid grid-cols-2 gap-1.5">
                            <button
                              type="button"
                              onClick={() => setRestoreMode("merge")}
                              className={`py-1 px-2 text-[9px] font-extrabold rounded-md border text-center transition-all cursor-pointer ${
                                restoreMode === "merge"
                                  ? "bg-blue-600 border-blue-600 text-white shadow-xs"
                                  : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50"
                              }`}
                            >
                              マージ（重複を避けて追加）
                            </button>
                            <button
                              type="button"
                              onClick={() => setRestoreMode("overwrite")}
                              className={`py-1 px-2 text-[9px] font-extrabold rounded-md border text-center transition-all cursor-pointer ${
                                restoreMode === "overwrite"
                                  ? "bg-rose-600 border-rose-600 text-white shadow-xs"
                                  : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50"
                              }`}
                            >
                              上書き（既存をすべて消去）
                            </button>
                          </div>

                          <div className="flex items-center justify-end gap-1.5 pt-1">
                            <button
                              type="button"
                              onClick={() => setIsConfirmingRestore(null)}
                              className="px-2.5 py-1 text-[9px] font-black text-slate-500 hover:bg-slate-100 rounded-md transition-colors cursor-pointer"
                            >
                              キャンセル
                            </button>
                            <button
                              type="button"
                              onClick={() => handleRestoreBackup(file.id)}
                              disabled={isActionLoading}
                              className={`px-3.5 py-1 text-[9px] font-black text-white rounded-md transition-all shadow-xs cursor-pointer ${
                                restoreMode === "overwrite" ? "bg-rose-600 hover:bg-rose-700" : "bg-blue-600 hover:bg-blue-700"
                              }`}
                            >
                              {isActionLoading ? (
                                <span className="flex items-center gap-1">
                                  <Loader2 className="w-2.5 h-2.5 animate-spin" />
                                  処理中...
                                </span>
                              ) : (
                                "復元を実行"
                              )}
                            </button>
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        </div>
      ) : (
        <div className="p-3.5 bg-slate-100 rounded-xl border border-slate-200 flex flex-col items-center justify-center text-center space-y-2">
          <CloudRain className="w-6 h-6 text-slate-400" />
          <p className="text-[10px] text-slate-500 font-extrabold leading-normal max-w-sm">
            Google Driveに接続すると、パソコンやスマートフォンの間でデータベース全体を安全に保存・転送できるようになります。
          </p>
        </div>
      )}
    </div>
  );
}
